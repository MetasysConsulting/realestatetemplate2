{"route":"/","file":"foreclosure-prototype.html","bodyClass":"","title":"ForeclosureIQ — Distressed Property Intelligence","html":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>ForeclosureIQ — Distressed Property Intelligence</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --navy:#0B1F3A; --navy-2:#11294B;\n    --blue:#1E63E9; --blue-bright:#3B82F6; --blue-soft:#E8F0FE; --sky:#5AA9F0;\n    --ink:#0E1726; --slate:#5B6B82; --line:#E3E9F2; --bg:#F4F7FC; --white:#FFFFFF;\n    --green:#16A34A; --amber:#E08A1E; --red:#DC3545; --violet:#7C3AED; --teal:#0E9488;\n    --shadow:0 10px 30px rgba(13,38,76,.10); --radius:16px;\n  }\n  *{box-sizing:border-box;margin:0;padding:0}\n  body{font-family:'Lexend',system-ui,sans-serif;background:var(--bg);color:var(--ink);line-height:1.55;-webkit-font-smoothing:antialiased}\n  a{color:inherit;text-decoration:none}\n  h1,h2,h3,h4{line-height:1.15;font-weight:700;letter-spacing:-.01em}\n  .wrap{max-width:1180px;margin:0 auto;padding:0 20px}\n  .hidden{display:none!important}\n\n  /* NAV */\n  header{background:var(--navy);color:#fff;position:sticky;top:0;z-index:50}\n  .nav{display:flex;align-items:center;justify-content:space-between;height:66px}\n  .logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:20px}\n  .logo .mark{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,var(--blue-bright),var(--sky));display:grid;place-items:center;font-size:15px}\n  .logo b{color:var(--sky)}\n  .nav-links{display:flex;gap:26px;font-size:14px;font-weight:500;color:#C6D3E6}\n  .nav-links a:hover{color:#fff}\n  .nav-cta{display:flex;gap:10px;align-items:center}\n  .btn{border:none;cursor:pointer;font-family:'Lexend';font-weight:600;font-size:14px;padding:10px 18px;border-radius:10px;transition:.15s}\n  .btn-ghost{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.25)}\n  .btn-ghost:hover{background:rgba(255,255,255,.08)}\n  .btn-primary{background:var(--blue);color:#fff}\n  .btn-primary:hover{background:var(--blue-bright)}\n  @media(max-width:820px){.nav-links{display:none}}\n\n  /* HERO */\n  .hero{background:radial-gradient(900px 400px at 80% -20%, rgba(59,130,246,.35), transparent 60%),linear-gradient(180deg,var(--navy),var(--navy-2));color:#fff;padding:50px 0 84px;position:relative;overflow:hidden}\n  .hero::after{content:\"\";position:absolute;inset:0;opacity:.07;background-image:linear-gradient(rgba(255,255,255,.6) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.6) 1px,transparent 1px);background-size:44px 44px;mask-image:radial-gradient(circle at 50% 0%,#000,transparent 70%)}\n  .hero .wrap{position:relative;z-index:1}\n  .tagline{display:inline-flex;align-items:center;gap:8px;background:rgba(90,169,240,.15);border:1px solid rgba(90,169,240,.35);color:#BBD7F7;border-radius:100px;padding:6px 14px;font-size:12.5px;font-weight:500;margin-bottom:18px}\n  .dot{width:7px;height:7px;border-radius:50%;background:#4ADE80;box-shadow:0 0 0 4px rgba(74,222,128,.2)}\n  .hero h1{font-size:clamp(30px,5.4vw,50px);font-weight:800;max-width:16ch}\n  .hero h1 em{font-style:normal;color:var(--sky)}\n  .hero p{color:#AFC0DA;margin-top:14px;font-size:clamp(15px,2.2vw,17px);max-width:54ch;font-weight:300}\n  .searchbar{margin-top:30px;background:#fff;border-radius:16px;padding:8px;display:flex;gap:8px;box-shadow:var(--shadow);max-width:780px;flex-wrap:wrap}\n  .searchbar .field{flex:1;min-width:150px;padding:8px 14px;display:flex;flex-direction:column;border-radius:10px}\n  .searchbar .field:hover{background:var(--bg)}\n  .searchbar label{font-size:10.5px;font-weight:700;color:var(--slate);text-transform:uppercase;letter-spacing:.06em}\n  .searchbar select,.searchbar input{border:none;background:transparent;font-family:'Lexend';font-size:14.5px;font-weight:500;color:var(--ink);outline:none;margin-top:3px}\n  .searchbar .go{padding:0 26px;background:var(--blue);color:#fff;border-radius:10px;font-weight:600;border:none;cursor:pointer;font-size:15px}\n  .searchbar .go:hover{background:var(--blue-bright)}\n  .stats{display:flex;gap:34px;margin-top:30px;flex-wrap:wrap}\n  .stat b{font-size:24px;display:block;color:#fff;font-weight:800}\n  .stat span{font-size:12.5px;color:#9FB2CE;font-weight:300}\n\n  /* LIST */\n  main{padding:34px 0 60px}\n  .toolbar{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:22px}\n  .chips{display:flex;gap:9px;flex-wrap:wrap}\n  .chip{border:1px solid var(--line);background:#fff;border-radius:100px;padding:8px 15px;font-size:13px;font-weight:500;color:var(--slate);cursor:pointer;transition:.15s}\n  .chip:hover{border-color:var(--sky)}\n  .chip.active{background:var(--navy);color:#fff;border-color:var(--navy)}\n  .result-count{font-size:13.5px;color:var(--slate);font-weight:500}\n  .result-count b{color:var(--ink);font-weight:700}\n  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:20px}\n  .card{background:#fff;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;cursor:pointer;transition:.18s;display:flex;flex-direction:column}\n  .card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:#cdd9ec}\n  .thumb{height:170px;position:relative;background:linear-gradient(135deg,#1b3a63,#27568c);display:grid;place-items:center;overflow:hidden}\n  .thumb .glass{position:absolute;inset:0;backdrop-filter:blur(2px);background:rgba(11,31,58,.15);display:grid;place-items:center}\n  .lockpill{background:rgba(255,255,255,.92);color:var(--navy);font-size:11.5px;font-weight:600;padding:6px 12px;border-radius:100px;display:flex;align-items:center;gap:6px}\n  .badge{font-size:11px;font-weight:600;color:#fff;padding:5px 11px;border-radius:7px;letter-spacing:.02em}\n  .thumb .badge{position:absolute;top:12px;left:12px}\n  .b-pre{background:var(--amber)} .b-auction{background:var(--red)} .b-reo{background:var(--blue)} .b-tax{background:var(--violet)} .b-short{background:var(--teal)}\n  .equity-tag{position:absolute;top:12px;right:12px;background:rgba(22,163,74,.95);color:#fff;font-size:11px;font-weight:700;padding:5px 10px;border-radius:7px}\n  .card-body{padding:15px 16px 17px}\n  .price{font-weight:800;font-size:21px}\n  .price small{font-size:12px;color:var(--slate);font-weight:500}\n  .addr{display:flex;align-items:center;gap:7px;margin-top:6px;color:var(--slate);font-size:13.5px;font-weight:500}\n  .addr .blur{filter:blur(4.5px);user-select:none;color:var(--ink)}\n  .specs{display:flex;gap:14px;margin-top:13px;padding-top:13px;border-top:1px solid var(--line);font-size:13px;color:var(--slate);font-weight:500}\n  .specs b{color:var(--ink);font-weight:700}\n\n  /* ---- DETAIL (Proty-style) ---- */\n  .backbar{background:#fff;border-bottom:1px solid var(--line);padding:14px 0}\n  .backbar .wrap{display:flex;align-items:center;gap:8px}\n  .crumb{font-size:13px;color:var(--slate);font-weight:500}\n  .crumb b{color:var(--ink)}\n  .back-btn{background:var(--blue-soft);color:var(--blue);border:none;cursor:pointer;font-weight:600;font-size:13.5px;padding:9px 16px;border-radius:9px;font-family:'Lexend'}\n  .back-btn:hover{background:#d8e6fd}\n\n  .gallery{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:1fr 1fr;gap:10px;margin-top:22px;height:380px}\n  .gtile{background:linear-gradient(135deg,#1b3a63,#2d5fa0);border-radius:12px;position:relative;display:grid;place-items:center;overflow:hidden}\n  .gtile.main{grid-row:span 2}\n  .gtile .glass{position:absolute;inset:0;backdrop-filter:blur(3px);background:rgba(11,31,58,.25);display:grid;place-items:center}\n  .photos-pill{position:absolute;bottom:12px;right:12px;background:rgba(255,255,255,.92);color:var(--navy);font-size:12px;font-weight:600;padding:7px 13px;border-radius:9px;display:flex;gap:6px;align-items:center}\n  @media(max-width:760px){.gallery{grid-template-columns:1fr 1fr;height:auto}.gtile.main{grid-row:span 1;height:200px}.gtile:not(.main){height:120px}}\n\n  .d-grid{display:grid;grid-template-columns:1fr 360px;gap:28px;margin-top:26px;align-items:start}\n  @media(max-width:920px){.d-grid{grid-template-columns:1fr}}\n\n  .d-headrow{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:flex-start}\n  .d-title{font-size:26px;font-weight:800}\n  .d-addr{margin-top:6px;color:var(--slate);font-weight:500;font-size:14.5px;display:flex;align-items:center;gap:8px}\n  .d-addr .blur{filter:blur(6px);user-select:none}\n  .d-price{font-size:30px;font-weight:800;text-align:right}\n  .d-price small{display:block;font-size:12.5px;color:var(--slate);font-weight:500}\n\n  .overview{display:flex;gap:10px;flex-wrap:wrap;margin-top:20px}\n  .ov{flex:1;min-width:96px;background:#fff;border:1px solid var(--line);border-radius:12px;padding:14px;text-align:center}\n  .ov .ic{font-size:18px}\n  .ov b{display:block;font-size:16px;font-weight:700;margin-top:4px}\n  .ov span{font-size:11.5px;color:var(--slate)}\n\n  .panel{background:#fff;border:1px solid var(--line);border-radius:14px;padding:20px 22px;margin-top:18px}\n  .panel h3{font-size:17px;margin-bottom:14px;display:flex;align-items:center;gap:9px}\n  .panel h3 .ic{color:var(--blue)}\n  .panel p{color:#3c4961;font-size:14.5px;font-weight:300}\n\n  .detail-list{display:grid;grid-template-columns:1fr 1fr;gap:0 30px}\n  .detail-list .row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--line);font-size:14px}\n  .detail-list .row span{color:var(--slate);font-weight:300}\n  .detail-list .row b{font-weight:600}\n  @media(max-width:560px){.detail-list{grid-template-columns:1fr}}\n\n  .equity-row{display:flex;justify-content:space-between;font-size:13px;font-weight:500;margin-bottom:7px}\n  .equity-row span{color:var(--slate)}\n  .bar{height:12px;border-radius:8px;background:var(--line);overflow:hidden;display:flex}\n  .bar .owed{background:#94A3B8} .bar .eq{background:linear-gradient(90deg,#16A34A,#22C55E)}\n  .equity-final{margin-top:12px;font-size:14px;font-weight:600}\n  .equity-final b{color:var(--green);font-size:18px;font-weight:800}\n\n  .tl{position:relative;margin-left:6px;padding-left:22px;border-left:2px solid var(--line)}\n  .tl-item{position:relative;padding-bottom:16px}\n  .tl-item:last-child{padding-bottom:0}\n  .tl-item::before{content:\"\";position:absolute;left:-29px;top:2px;width:13px;height:13px;border-radius:50%;background:#fff;border:3px solid var(--sky)}\n  .tl-item.done::before{background:var(--blue);border-color:var(--blue)}\n  .tl-item.next::before{background:#fff;border-color:var(--red);box-shadow:0 0 0 4px rgba(220,53,69,.15)}\n  .tl-date{font-size:12px;color:var(--slate);font-weight:600}\n  .tl-title{font-size:14px;font-weight:600;margin-top:1px}\n\n  .dealscore{display:flex;align-items:center;gap:14px}\n  .ds-num{width:62px;height:62px;border-radius:14px;display:grid;place-items:center;color:#fff;font-weight:800;font-size:24px;background:linear-gradient(135deg,#16A34A,#22C55E)}\n  .ds-txt{font-size:13px;color:var(--slate);font-weight:300}\n  .ds-txt b{color:var(--ink);font-size:14px;display:block;font-weight:600}\n\n  .features{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}\n  .features div{font-size:13.5px;color:#3c4961;display:flex;align-items:center;gap:8px;font-weight:300}\n  .features .ck{color:var(--green);font-weight:700}\n  @media(max-width:560px){.features{grid-template-columns:1fr 1fr}}\n\n  .mapbox{height:200px;border-radius:12px;background:linear-gradient(135deg,#e2ecf8,#cfe0f5);position:relative;display:grid;place-items:center;border:1px solid var(--line)}\n  .mapbox .pin{font-size:30px;filter:blur(1px)}\n  .mapbox .note{position:absolute;bottom:10px;font-size:12px;color:var(--slate);background:#fff;padding:5px 10px;border-radius:7px}\n\n  /* sticky sidebar paywall */\n  .side{position:sticky;top:84px;display:flex;flex-direction:column;gap:16px}\n  .paywall{background:#fff;border:1px solid var(--line);border-radius:16px;overflow:hidden;box-shadow:var(--shadow)}\n  .pw-head{background:linear-gradient(135deg,var(--navy),var(--navy-2));color:#fff;padding:18px 20px}\n  .pw-head .lk{font-size:22px}\n  .pw-head h4{font-size:17px;margin-top:6px;font-weight:700}\n  .pw-head p{font-size:12.5px;color:#AFC0DA;font-weight:300;margin-top:3px}\n  .pw-body{padding:18px 20px}\n  .gated{position:relative}\n  .gated .locked-content{filter:blur(7px);user-select:none;pointer-events:none}\n  .lock-grid .it{padding:9px 0;border-bottom:1px solid var(--line);font-size:13.5px}\n  .lock-grid .it:last-child{border-bottom:none}\n  .lock-grid .it span{color:var(--slate);font-size:11.5px;display:block;font-weight:300}\n  .lock-grid .it b{font-weight:600}\n  .pw-btns{display:flex;flex-direction:column;gap:9px;margin-top:4px}\n  .btn-block{width:100%;padding:13px;border-radius:11px;font-weight:600;font-size:14px;cursor:pointer;border:none;font-family:'Lexend'}\n  .btn-unlock{background:var(--blue);color:#fff} .btn-unlock:hover{background:var(--blue-bright)}\n  .btn-sub{background:#fff;color:var(--navy);border:1.5px solid var(--line)} .btn-sub:hover{border-color:var(--sky)}\n  .pw-secure{font-size:11.5px;color:var(--slate);text-align:center;margin-top:12px;font-weight:300}\n  .unlocked-note{display:none;align-items:center;gap:8px;color:var(--green);font-weight:600;font-size:13px;margin-top:12px}\n\n  .estimator{background:#fff;border:1px solid var(--line);border-radius:16px;padding:18px 20px}\n  .estimator h4{font-size:14px;margin-bottom:12px;color:var(--slate);font-weight:600}\n  .est-row{display:flex;justify-content:space-between;padding:7px 0;font-size:14px}\n  .est-row span{color:var(--slate);font-weight:300}\n  .est-row b{font-weight:600}\n  .est-row.total{border-top:1px solid var(--line);margin-top:6px;padding-top:12px;font-size:15px}\n  .est-row.total b{color:var(--green);font-size:18px;font-weight:800}\n\n  footer{background:var(--navy);color:#9FB2CE;padding:30px 0;font-size:13px;text-align:center;font-weight:300}\n  .demo-flag{background:#FFF7E6;border-bottom:1px solid #F4D58A;color:#8A5A00;font-size:12.5px;font-weight:500;text-align:center;padding:9px}\n</style>\n</head>\n<body>\n\n<div class=\"demo-flag\">Prototype preview · sample Florida listings for demonstration · data not yet live</div>\n\n<header>\n  <div class=\"wrap nav\">\n    <div class=\"logo\" onclick=\"showList()\" style=\"cursor:pointer\"><span class=\"mark\">◆</span>Foreclosure<b>IQ</b></div>\n    <nav class=\"nav-links\"><a href=\"#\" onclick=\"showList()\">Browse</a><a href=\"#\">Map</a><a href=\"#\">Auctions</a><a href=\"#\">Pricing</a><a href=\"#\">How it works</a></nav>\n    <div class=\"nav-cta\"><button class=\"btn btn-ghost\">Sign in</button><button class=\"btn btn-primary\">Get started</button></div>\n  </div>\n</header>\n\n<!-- ============ LISTING VIEW ============ -->\n<div id=\"listingView\">\n  <section class=\"hero\">\n    <div class=\"wrap\">\n      <span class=\"tagline\"><span class=\"dot\"></span> Updated daily · 50 states + DC</span>\n      <h1>Find <em>distressed & foreclosure</em> properties before everyone else.</h1>\n      <p>Pre-foreclosures, auctions, bank-owned, and tax-delinquent homes across the U.S. — with equity estimates and owner contacts, all in one modern platform.</p>\n      <div class=\"searchbar\">\n        <div class=\"field\"><label>Location</label><input value=\"Miami-Dade, FL\" /></div>\n        <div class=\"field\"><label>Distress type</label><select><option>All types</option><option>Pre-foreclosure</option><option>Auction</option><option>Bank-owned (REO)</option><option>Tax-delinquent</option></select></div>\n        <div class=\"field\"><label>Max price</label><select><option>Any</option><option>$200k</option><option>$350k</option><option>$500k</option></select></div>\n        <button class=\"go\">Search</button>\n      </div>\n      <div class=\"stats\">\n        <div class=\"stat\"><b>14,820</b><span>Active listings in FL</span></div>\n        <div class=\"stat\"><b>1.2M+</b><span>Properties nationwide</span></div>\n        <div class=\"stat\"><b>Daily</b><span>Auto-refreshed data</span></div>\n      </div>\n    </div>\n  </section>\n\n  <main>\n    <div class=\"wrap\">\n      <div class=\"toolbar\">\n        <div class=\"chips\">\n          <div class=\"chip active\">All</div><div class=\"chip\">Pre-foreclosure</div><div class=\"chip\">Auction</div><div class=\"chip\">Bank-owned</div><div class=\"chip\">Tax-delinquent</div><div class=\"chip\">Short sale</div>\n        </div>\n        <div class=\"result-count\"><b>14,820</b> results · Miami-Dade, FL</div>\n      </div>\n      <div class=\"grid\" id=\"grid\"></div>\n    </div>\n  </main>\n</div>\n\n<!-- ============ DETAIL VIEW ============ -->\n<div id=\"detailView\" class=\"hidden\">\n  <div class=\"backbar\"><div class=\"wrap\">\n    <button class=\"back-btn\" onclick=\"showList()\">← Back to results</button>\n    <span class=\"crumb\">Florida &nbsp;›&nbsp; Miami-Dade &nbsp;›&nbsp; <b>Pre-Foreclosure</b></span>\n  </div></div>\n\n  <div class=\"wrap\">\n    <!-- gallery -->\n    <div class=\"gallery\">\n      <div class=\"gtile main\"><svg width=\"90\" height=\"90\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#a9c7ee\" stroke-width=\"1\"><path d=\"M3 11l9-8 9 8\"/><path d=\"M5 10v10h14V10\"/><path d=\"M9 20v-6h6v6\"/></svg><div class=\"glass\"></div><span class=\"photos-pill\">📷 +10 photos · unlock to view</span></div>\n      <div class=\"gtile\"><div class=\"glass\"><span class=\"lockpill\">🔒 Locked</span></div></div>\n      <div class=\"gtile\"><div class=\"glass\"><span class=\"lockpill\">🔒 Locked</span></div></div>\n      <div class=\"gtile\"><div class=\"glass\"><span class=\"lockpill\">🔒 Locked</span></div></div>\n      <div class=\"gtile\"><div class=\"glass\"><span class=\"lockpill\">🔒 Locked</span></div></div>\n    </div>\n\n    <div class=\"d-grid\">\n      <!-- LEFT MAIN -->\n      <div>\n        <div class=\"d-headrow\">\n          <div>\n            <span class=\"badge b-pre\">Pre-Foreclosure</span>\n            <h1 class=\"d-title\" style=\"margin-top:10px\">3-Bed Single Family · Allapattah</h1>\n            <div class=\"d-addr\">📍 <span class=\"blur\" id=\"dAddr\">4421 NW 18th Avenue, Miami, FL 33142</span></div>\n          </div>\n          <div class=\"d-price\">$312,000<small>estimated value $410,000</small></div>\n        </div>\n\n        <div class=\"overview\">\n          <div class=\"ov\"><div class=\"ic\">🛏</div><b>3</b><span>Bedrooms</span></div>\n          <div class=\"ov\"><div class=\"ic\">🛁</div><b>2</b><span>Bathrooms</span></div>\n          <div class=\"ov\"><div class=\"ic\">📐</div><b>1,640</b><span>Sq Ft</span></div>\n          <div class=\"ov\"><div class=\"ic\">🌳</div><b>0.16</b><span>Acre lot</span></div>\n          <div class=\"ov\"><div class=\"ic\">📅</div><b>1998</b><span>Year built</span></div>\n          <div class=\"ov\"><div class=\"ic\">🏠</div><b>SFR</b><span>Type</span></div>\n        </div>\n\n        <div class=\"panel\">\n          <h3><span class=\"ic\">📝</span> Description</h3>\n          <p>Single-family residence in Allapattah currently in pre-foreclosure following a lis pendens filing. Owner is behind on payments with an auction scheduled in Miami-Dade County. Estimated equity position is strong relative to the outstanding balance, making this an early-stage opportunity for investors to act before the property reaches auction. Full address, owner of record, and direct contact are available upon unlock.</p>\n        </div>\n\n        <div class=\"panel\">\n          <h3><span class=\"ic\">📋</span> Property details</h3>\n          <div class=\"detail-list\">\n            